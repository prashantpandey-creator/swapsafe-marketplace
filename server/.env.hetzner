# ── SwapSafe Backend — Hetzner Config ─────────────────────────
# Copy to server/.env and fill in real values.
# MongoDB & Redis are provided by docker-compose (no external setup needed).

# Database (docker-compose internal network)
# NOTE: MONGODB_URI is set by docker-compose using the credentials below —
# Mongo runs with auth ON and is bound to 127.0.0.1 only. Never expose 27017 publicly.
MONGODB_URI=mongodb://swapsafe:CHANGE_ME@mongo:27017/swapsafe?authSource=admin

# Mongo/Redis credentials — also referenced by docker-compose (.env at repo root).
# Generate strong random values; do NOT reuse across services.
MONGO_INITDB_ROOT_USERNAME=swapsafe
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_strong_random
REDIS_PASSWORD=CHANGE_ME_strong_random

# Auth
JWT_SECRET=CHANGE_ME_to_a_random_string_64chars

# AI Providers — reuse your PuranGPT keys
GROQ_API_KEY=your_groq_key_from_purangpt
GEMINI_API_KEY=your_gemini_key_from_purangpt
OPENAI_API_KEY=optional_openai_key

# Image uploads (optional — app works without, uses base64 fallback)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Payments (optional — disable payment features if empty)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Server (set by docker-compose, listed here for reference)
PORT=5000
AI_ENGINE_URL=http://ai-engine:8001
CLIENT_URL=http://204.168.176.229:3010

# Redis (set by docker-compose; bound to 127.0.0.1 only, password required)
REDIS_HOST=redis
REDIS_PORT=6379
USE_REDIS=true
